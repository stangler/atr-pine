//@version=6
indicator("ATRフィルター + ATR倍率 TP/SL + 方向性判断", overlay=false)

// ==================== 入力設定 ====================
atr_period = input.int(14, "ATR期間", minval=1) // 標準は14
sl_mult = input.float(1.5, "SL 倍率 (損切り)", step=0.1)
tp_mult = input.float(3.0, "TP 倍率 (利確)", step=0.1)

// === 新規追加：方向性判断指標 ===
rsi_length     = input.int(14, "RSI期間", minval=1)
stoch_k_length = input.int(14, "Stochastic %K期間", minval=1)
stoch_d_length = input.int(3,  "Stochastic %D期間", minval=1)

// ATRフィルター用の閾値（元のまま）
var float thresh_ok = na
var float thresh_ng = na
if timeframe.multiplier == 1
    thresh_ok := 0.8
    thresh_ng := 1.5
else if timeframe.multiplier == 3
    thresh_ok := 1.2
    thresh_ng := 2.0
else
    thresh_ok := 1.5
    thresh_ng := 2.5

// ==================== ATR計算 ====================
atr_val = ta.atr(atr_period)
atr_pct = (atr_val / close) * 100 // フィルター用（%表示）

// ==================== 新規追加：方向性判断計算 ====================
rsi_val = ta.rsi(close, rsi_length)

stoch_k = ta.stoch(close, high, low, stoch_k_length)
stoch_d = ta.sma(stoch_k, stoch_d_length)

// ロング/ショート優勢判定
long_good  = rsi_val > 50 and stoch_k > stoch_d
short_good = rsi_val < 50 and stoch_k < stoch_d
bias_judge = long_good ? "🟢 ロング優勢" : short_good ? "🔴 ショート優勢" : "⚪ ニュートラル"
bias_col   = long_good ? color.lime : short_good ? color.red : color.gray

// 色分け（フィルター部分はそのまま）
col = atr_pct < thresh_ok ? color.blue : atr_pct < thresh_ng ? color.yellow : color.red

// ==================== TP/SL計算（ATR倍率版） ====================
entry = close
// ロング
l_sl = math.round(entry - (atr_val * sl_mult), 2)
l_tp = math.round(entry + (atr_val * tp_mult), 2)
// ショート
s_sl = math.round(entry + (atr_val * sl_mult), 2)
s_tp = math.round(entry - (atr_val * tp_mult), 2)

// ==================== 判定（フィルター部分はそのまま） ====================
judge = atr_pct < thresh_ok ? "✅ エントリー" : atr_pct < thresh_ng ? "⚠️ ロット半減" : "❌ 見送り"

// ==================== プロット ====================
plot(atr_pct, "ATR%", color=col, linewidth=2)
plot(thresh_ok, "エントリー", color=color.blue, linewidth=1)
plot(thresh_ng, "見送り", color=color.red, linewidth=1)

// ==================== テーブル表示 ====================
var table t = table.new(position.top_right, 2, 13,  // ← 13行に拡張
     bgcolor=color.new(color.black, 20),
     border_width=1, border_color=color.new(color.gray, 50))

if barstate.islast
    // ヘッダー行
    table.cell(t, 0, 0, "項目", text_color=color.white, bgcolor=color.new(color.gray, 70))
    table.cell(t, 1, 0, "値", text_color=color.white, bgcolor=color.new(color.gray, 70))
   
    table.cell(t, 0, 1, "ATR%", text_color=color.white, bgcolor=color.new(color.gray, 70))
    table.cell(t, 1, 1, str.tostring(atr_pct, "#.##") + "%", text_color=col)
   
    table.cell(t, 0, 2, "ATR判定", text_color=color.white, bgcolor=color.new(color.gray, 70))
    table.cell(t, 1, 2, judge, text_color=col)
   
    table.cell(t, 0, 3, "現在値", text_color=color.white, bgcolor=color.new(color.gray, 70))
    table.cell(t, 1, 3, str.tostring(entry, "#.####"), text_color=color.white)
   
    table.cell(t, 0, 4, "ATR値", text_color=color.white, bgcolor=color.new(color.gray, 70))
    table.cell(t, 1, 4, str.tostring(atr_val, "#.####"), text_color=color.yellow)
   
    // ロング
    table.cell(t, 0, 5, "▲ロング TP", text_color=color.blue, bgcolor=color.new(color.gray, 70))
    table.cell(t, 1, 5, str.tostring(l_tp, "#.####"), text_color=color.blue)
   
    table.cell(t, 0, 6, "▲ロング SL", text_color=color.red, bgcolor=color.new(color.gray, 70))
    table.cell(t, 1, 6, str.tostring(l_sl, "#.####"), text_color=color.red)
   
    // ショート
    table.cell(t, 0, 7, "▼ショート TP", text_color=color.blue, bgcolor=color.new(color.gray, 70))
    table.cell(t, 1, 7, str.tostring(s_tp, "#.####"), text_color=color.blue)
   
    table.cell(t, 0, 8, "▼ショート SL", text_color=color.red, bgcolor=color.new(color.gray, 70))
    table.cell(t, 1, 8, str.tostring(s_sl, "#.####"), text_color=color.red)

    // ==================== 新規追加：方向性判断表示 ====================
    table.cell(t, 0, 9, "RSI", text_color=color.white, bgcolor=color.new(color.gray, 70))
    table.cell(t, 1, 9, str.tostring(rsi_val, "#.##"), text_color=rsi_val > 50 ? color.lime : color.red)
   
    table.cell(t, 0, 10, "Stoch %K", text_color=color.white, bgcolor=color.new(color.gray, 70))
    table.cell(t, 1, 10, str.tostring(stoch_k, "#.##"), text_color=color.white)
   
    table.cell(t, 0, 11, "Stoch %D", text_color=color.white, bgcolor=color.new(color.gray, 70))
    table.cell(t, 1, 11, str.tostring(stoch_d, "#.##"), text_color=color.white)
   
    table.cell(t, 0, 12, "方向性判定", text_color=color.white, bgcolor=color.new(color.gray, 70))
    table.cell(t, 1, 12, bias_judge, text_color=bias_col, text_size=size.large)